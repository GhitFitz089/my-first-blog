---
Title: Home Page
BodyClass: home-page
---

@using Statiq.Common
@using System.Globalization

@{
    Layout = "_layout";

    // I post Markdown finiscono nella pipeline "Content"
    var posts = Context.Outputs
        .FromPipeline("Content")
        .Where(p =>// Filtriamo solo i file Markdown che hanno una data
            p.Source.Extension == ".md" &&
            p.ContainsKey("Date"))
        .OrderByDescending(p => p.GetDateTime("Date"))
        .Select(p => new
        {
            Titolo = p.GetString("Title") ?? p.Source.FileNameWithoutExtension.FullPath, // Se non c'è un titolo, usiamo il nome del file
            Progetto = p.GetString("Project") ?? "-", // Se non c'è un progetto associato, mostriamo un trattino
            Tema = p.GetString("Theme") ?? "GENERICO",
            DataLeggibile = p.GetDateTime("Date")
                .ToString("d", CultureInfo.GetCultureInfo("it-IT")),
            Link = p.GetLink()
        })
        .ToList();

    var projects = Context.Outputs
        .FromPipeline("Content")
        .Where(d =>// Filtriamo solo i documenti che hanno un metadato "Type" uguale a "Project"
            d.ContainsKey("Type") &&
            d.GetString("Type") == "Project")
        .Select(d => new // Creiamo un oggetto anonimo per ogni progetto, con i dati che ci interessano
        {
            Titolo = d.GetString("Title") ?? d.Source.FileNameWithoutExtension.FullPath,
            Descrizione = d.GetString("Summary") ?? "Nessuna descrizione disponibile.",
            Stato = d.GetString("Status") ?? "",
            Link = d.GetLink()
        })
        .ToList();     

}

<h1>Benvenuti nel mio "Digital Garden"</h1>

<p>
    Questo blog documenta il mio percorso tecnico tra sviluppo software,
    elettronica, fai-da-te e sperimentazione.
</p>

<hr />

<section class="home-projects">
    <h2>Progetti</h2>
    <p class="section-intro">
        Alcuni dei progetti su cui sto lavorando o che sto documentando nel tempo.
    </p>

    @if (projects.Any())
    {
        <div class="projects-scroll-shell">
            <div class="projects-arrow projects-arrow--left" aria-hidden="true">
                &#10094;
            </div>

            <div class="projects-scroll">
                @foreach (var project in projects)
                {
                    <article class="project-card">
                        @if (!string.IsNullOrWhiteSpace(project.Stato))
                        {
                            <span class="project-status">@project.Stato</span>
                        }

                        <h3 class="project-card-title">
                            <a href="@project.Link">@project.Titolo</a>
                        </h3>

                        <p class="project-card-summary">
                            @project.Descrizione
                        </p>

                        <a class="project-card-link" href="@project.Link">
                            Vai al progetto →
                        </a>
                    </article>
                }
            </div>

            <div class="projects-arrow projects-arrow--right" aria-hidden="true">
                &#10095;
            </div>
        </div>
    }
    else
    {
        <p class="post-empty">Nessun progetto trovato.</p>
    }
</section>

<h2>Ultimi aggiornamenti</h2>

@if (posts.Any())
{
    <ul class="post-list">
        @foreach (var post in posts)
        {
            <li class="post-item">
                <span class="post-theme">
                    @post.Tema
                </span>

                <a class="post-title" href="@post.Link">
                    @post.Titolo
                </a>

                <small class="post-meta">
                    Progetto: <strong>@post.Progetto</strong> |
                    Data: @post.DataLeggibile
                </small>
            </li>
        }
    </ul>
}
else
{
    <p class="post-empty">Nessun post trovato.</p>
}

