---
Title: Home Page
---
@using Statiq.Common
@using System.Globalization

@{
    Layout = "_layout";

    // I post Markdown finiscono nella pipeline "Content"
    var posts = Context.Outputs
        .FromPipeline("Content")
        .Where(p =>
            p.Source.Extension == ".md" &&
            p.ContainsKey("Date"))
        .OrderByDescending(p => p.GetDateTime("Date"))
        .Select(p => new
        {
            Titolo = p.GetString("Title") ?? p.Source.FileNameWithoutExtension.FullPath,
            Progetto = p.GetString("Project") ?? "-",
            Tema = p.GetString("Theme") ?? "GENERICO",
            DataLeggibile = p.GetDateTime("Date")
                .ToString("d", CultureInfo.GetCultureInfo("it-IT")),
            Link = p.GetLink()
        })
        .ToList();
}

<h1>Benvenuti nel mio "Digital Garden"</h1>

<p>
    Questo blog documenta il mio percorso tecnico tra sviluppo software,
    elettronica, fai-da-te e sperimentazione.
</p>

<hr />

<section class="home-projects">
    <h2>Scegli un progetto</h2>
    <ul class="project-list">
        <li class="project-item">
            <h3>Il mio blog in Statiq</h3>
            <p>
                Un diario di sviluppo del mio blog personale, costruito con Statiq.
                Dalla configurazione iniziale alla gestione dei contenuti, condivido
                le scelte tecniche e le sfide affrontate.
            </p>
            <a href="/projects">Il mio blog in Statiq →</a>
        </li>
        
        <li class="project-item">
            <h3>Home server & self hosting</h3>
            <p>
                Esplorazione del mondo del self hosting, con focus su Home Assistant,
                Nextcloud e altre soluzioni per portare i servizi online a casa.
            </p>
            <a href="/projects">Home server & self hosting →</a>
        </li>

        <li class="project-item">
            <h3>Sensore di parcheggio per il garage</h3>
            <p>
                Progetto di Elettronica e IoT per aiutare mia moglie a parcheggiare in garage senza occupare due posti.
            </p>
            <a href="/projects">Sensore di parcheggio per il garage →</a>
        </li>
    </ul>
</section>

<h2>Ultimi aggiornamenti</h2>

@if (posts.Any())
{
    <ul class="post-list">
        @foreach (var post in posts)
        {
            <li class="post-item">
                <span class="post-theme">
                    @post.Tema
                </span>

                <a class="post-title" href="@post.Link">
                    @post.Titolo
                </a>

                <small class="post-meta">
                    Progetto: <strong>@post.Progetto</strong> |
                    Data: @post.DataLeggibile
                </small>
            </li>
        }
    </ul>
}
else
{
    <p class="post-empty">Nessun post trovato.</p>
}

