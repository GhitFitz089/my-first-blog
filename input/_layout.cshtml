@using Statiq.Common
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    @* Usiamo l'indicizzatore ["Title"] che è più semplice per il compilatore *@
    <title>@Model["Title"]</title>
    <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body>
    @{
    var isHomePage = Document.GetLink() == "/" || Document.GetLink() == "/index.html";
}

<div class="container @(isHomePage ? "container--home" : "")">
        <header>
            <h1>My IT blog</h1>
            <nav>
                <a href="/">Home</a> | 
                <a href="#">Programmazione</a> |
                <a href="#">Elettronica</a> |
                <a href="#">Fai da te</a> |
                <a href="#">Stampa 3D</a> |
                <a href="#">Linux & Home server</a> |
                <a href="#">La mia vita</a> |
                <a href="#">Chi Sono</a> |
                <a href="#">Contatti</a>
            </nav>
        </header>

        <main>
            @RenderBody() 
        </main>

        <footer>
            <p>© 2025 - Il mio viaggio tecnologico</p>
        </footer>
    </div>
</body>
</html>